# Copy to .env and fill in. .env is git-ignored.

# --- Adbo-Engine extension backend (server/) ---
# Port the local server listens on; the nav-extension targets this port.
# ADBO_PORT=8137

# Path to the external US-address xlsx the form-filler reads row-by-row.
# Defaults to D:\Work\Projects\AdrUs-Engine\data\us_address.xlsx if unset.
# ADBO_ADDRESS_XLSX=D:\us_address.xlsx

# URL the extension loads to start the redirect loop (fetched at Start via
# /api/config). Add as many numbered entries as you need; the extension cycles
# through them one per funnel run.
# ADBO_SOURCE_URL_1=https://glstrk.com/?offer_ids=xxxxxx&affiliate_id=xxxxxx
# ADBO_SOURCE_URL_2=https://glstrk.com/?offer_ids=yyyyyy&affiliate_id=yyyyyy

# Target percentage of funnel runs that reach the reward page (0–100). The rest
# drop off mid-funnel to simulate users losing interest. Default: 100.
# SUCCESS_RATE=60
